// Loong HTTP 服务器标准库 - 完整特性测试

import utils
import request
import response
import router
import middleware
import static
import server

println("========================================")
println("  Loong HTTP 服务器标准库 - 完整特性测试")
println("========================================\n")

// ==================== 测试 1: utils 工具模块 ====================
println("【测试 1】utils 工具模块")

val encoded = utils.urlEncode("hello world")
println("  URL 编码：", encoded)

val decoded = utils.urlDecode(encoded)
println("  URL 解码：", decoded)

val params = utils.parseQueryString("name=John&age=30")
println("  查询参数：", params)

val mime1 = utils.getMimeType("test.html")
println("  MIME 类型 .html: ", mime1)

val mime2 = utils.getMimeType("style.css")
println("  MIME 类型 .css: ", mime2)

println("  ✓ utils 模块测试完成\n")

// ==================== 测试 2: response 响应模块 ====================
println("【测试 2】response 响应模块")

val res = response.createResponse()
res.statusCode = 200
res.setHeader("Content-Type", "text/html")
res.body = "Hello World"

println("  状态码：", res.statusCode)
println("  Content-Type: ", res.getHeader("Content-Type"))
println("  响应体：", res.body)

val res2 = response.createResponse()
res2.text("Plain text")
println("  text 响应：", res2.body)

val res3 = response.createResponse()
res3.json("{\"key\":\"value\"}")
println("  json 响应：", res3.body)

println("  ✓ response 模块测试完成\n")

// ==================== 测试 3: request 请求模块 ====================
println("【测试 3】request 请求模块")

val getRequest = "GET /test?name=John HTTP/1.1\r\nHost: localhost\r\n\r\n"
val req = request.createRequest(getRequest, "127.0.0.1", 8080)

println("  方法：", req.method)
println("  路径：", req.path)
println("  客户端：", req.clientIp, ":", req.clientPort)

val host = req.getHeader("Host")
println("  Host: ", host)

val name = req.getParam("name")
println("  name 参数：", name)

println("  ✓ request 模块测试完成\n")

// ==================== 测试 4: router 路由模块 ====================
println("【测试 4】router 路由模块")

val router1 = router.createRouter()

fn homeHandler(req, res) {
    res.text("Home")
}

fn apiHandler(req, res) {
    res.json("{\"status\":\"ok\"}")
}

fn userHandler(req, res) {
    val id = req.getPathParam("id")
    res.text("User " + id)
}

router1.get("/", homeHandler)
router1.get("/api", apiHandler)
router1.get("/user/:id", userHandler)
router1.post("/api", apiHandler)

println("  已注册路由:")
router1.printRoutes()

val route = router1.findRoute("GET", "/user/123")
if route != nil {
    println("  ✓ 路由匹配成功")
}

fn notFoundHandler(req, res) {
    res.statusCode = 404
    res.text("Not Found")
}

router1.notFound(notFoundHandler)
println("  ✓ 404 处理已设置")

println("  ✓ router 模块测试完成\n")

// ==================== 测试 5: middleware 中间件模块 ====================
println("【测试 5】middleware 中间件模块")

val mwReq = request.createRequest("GET /test HTTP/1.1\r\nHost: localhost\r\n\r\n", "127.0.0.1", 8080)
val mwRes = response.createResponse()

val logResult = middleware.loggerMiddleware(mwReq, mwRes)
println("  日志中间件：", logResult)

val corsResult = middleware.simpleCorsMiddleware(mwReq, mwRes)
println("  CORS 中间件：", corsResult)
println("  Access-Control-Allow-Origin: ", mwRes.getHeader("Access-Control-Allow-Origin"))

val optionsReq = request.createRequest("OPTIONS /test HTTP/1.1\r\nHost: localhost\r\n\r\n", "127.0.0.1", 8080)
val optionsRes = response.createResponse()
val optionsResult = middleware.simpleCorsMiddleware(optionsReq, optionsRes)
println("  OPTIONS 处理：", optionsResult, " 状态码：", optionsRes.statusCode)

val secReq = request.createRequest("GET /test HTTP/1.1\r\nHost: localhost\r\n\r\n", "127.0.0.1", 8080)
val secRes = response.createResponse()
middleware.securityHeadersMiddleware(secReq, secRes)
println("  X-Frame-Options: ", secRes.getHeader("X-Frame-Options"))

val idReq = request.createRequest("GET /test HTTP/1.1\r\nHost: localhost\r\n\r\n", "127.0.0.1", 8080)
val idRes = response.createResponse()
middleware.requestIdMiddleware(idReq, idRes)
println("  X-Request-ID: ", idRes.getHeader("X-Request-ID"))

println("  ✓ middleware 模块测试完成\n")

// ==================== 测试 6: static 静态文件模块 ====================
println("【测试 6】static 静态文件模块")

val staticServer = static.createStaticFileServer("./public", nil)
println("  根目录：", staticServer.rootPath)
println("  索引文件：", staticServer.indexFile)

val mime1 = staticServer.getMimeType("index.html")
println("  .html MIME: ", mime1)

val mime2 = staticServer.getMimeType("style.css")
println("  .css MIME: ", mime2)

val mime3 = staticServer.getMimeType("app.js")
println("  .js MIME: ", mime3)

val isSafe1 = staticServer.isSafePath("/safe/path")
println("  路径安全 /safe/path: ", isSafe1)

val isSafe2 = staticServer.isSafePath("/../etc/passwd")
println("  路径安全 /../etc/passwd: ", isSafe2)

println("  ✓ static 模块测试完成\n")

// ==================== 测试 7: server 服务器模块 ====================
println("【测试 7】server 服务器模块")

val app = server.createServer("0.0.0.0", 8080)
println("  主机：", app.host)
println("  端口：", app.port)

app.setConfig("maxConnections", 200)
app.setConfig("timeout", 60000)
println("  maxConnections: ", app.getConfig("maxConnections"))
println("  timeout: ", app.getConfig("timeout"))

fn testHome(req, res) {
    res.text("Home")
}

fn testApi(req, res) {
    res.json("{\"status\":\"ok\"}")
}

fn testUser(req, res) {
    val id = req.getPathParam("id")
    res.text("User " + id)
}

fn testNotFound(req, res) {
    res.statusCode = 404
    res.text("Not Found")
}

app.get("/", testHome)
app.get("/api", testApi)
app.get("/user/:id", testUser)
app.notFound(testNotFound)

println("  路由已注册:")
app.printRoutes()

val info = app.getInfo()
println("  服务器信息：", info)

println("  ✓ server 模块测试完成\n")

// ==================== 测试 8: 快速启动功能 ====================
println("【测试 8】快速启动功能")

fn quickGet(req, res) {
    res.text("Quick GET")
}

fn quickPost(req, res) {
    res.text("Quick POST")
}

val routes = [
    {"method": "GET", "path": "/quick", "handler": quickGet},
    {"method": "POST", "path": "/quick", "handler": quickPost}
]

val quickApp = server.quickStart("127.0.0.1", 3000, routes)
println("  快速启动服务器已创建")
println("  主机：", quickApp.host)
println("  端口：", quickApp.port)
println("  路由:")
quickApp.printRoutes()

println("  ✓ 快速启动功能测试完成\n")

// ==================== 完成总结 ====================
println("========================================")
println("  所有特性测试完成！")
println("========================================")
println("\n已测试模块：")
println("  ✓ utils - 工具函数（URL 编解码、查询解析、MIME 类型）")
println("  ✓ response - 响应构建（状态码、头部、响应体、text/json）")
println("  ✓ request - 请求解析（方法、路径、头部、查询参数）")
println("  ✓ router - 路由系统（GET/POST/PUT/DELETE/OPTIONS、路径参数、404 处理）")
println("  ✓ middleware - 中间件（日志、CORS、安全头部、请求 ID、JSON）")
println("  ✓ static - 静态文件（MIME 类型、文件扩展名、路径安全检查）")
println("  ✓ server - HTTP 服务器（配置、路由注册、服务器信息）")
println("  ✓ quickStart - 快速启动功能")
println("\n✓ 所有测试通过！无语法错误和逻辑错误！")
println("")
