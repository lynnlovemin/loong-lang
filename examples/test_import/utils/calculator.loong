// Loong v1.2.4 import 功能测试模块
// 位置: examples/test_import/utils/calculator.loong

fn add(a, b) {
    return a + b
}

fn subtract(a, b) {
    return a - b
}

fn multiply(a, b) {
    return a * b
}

fn divide(a, b) {
    if b == 0 {
        throw "除数不能为零"
    }
    return a / b
}

val VERSION = "1.0.0"
