// ====================
// 11. 异常处理
// ====================

println("\n=== 异常处理 ===")

// try-catch
try {
    throw "这是一个测试异常"
} catch (err) {
    println("捕获异常: ", err)
}

// try-catch-finally
val resource = "已打开"
try {
    println("处理资源...")
    throw "处理出错"
} catch (e) {
    println("错误: ", e)
} finally {
    println("清理资源: ", resource)
}

// ====================
// 12. 类和对象
// ====================

println("\n=== 类和对象 ===")

// 基本类定义
class Animal {
    fn __init__(name, age) {
        self.name = name
        self.age = age
    }
    
    fn speak() {
        return "Some sound"
    }
    
    fn info() {
        return self.name + " (" + str(self.age) + " years old)"
    }
}

// 创建对象
val animal = Animal("Generic", 5)
println("animal.info(): ", animal.info())
println("animal.speak(): ", animal.speak())

// 继承
class Dog : Animal {
    fn __init__(name, age, breed) {
        super.__init__(name, age)
        self.breed = breed
    }
    
    fn speak() {
        return "Woof!"
    }
    
    fn info() {
        return super.info() + " - " + self.breed
    }
}

val dog = Dog("Buddy", 3, "Golden Retriever")
println("dog.info(): ", dog.info())
println("dog.speak(): ", dog.speak())

// 计数器类
class Counter {
    fn __init__() {
        self.count = 0
    }
    
    fn increment() {
        self.count = self.count + 1
        return self.count
    }
    
    fn decrement() {
        self.count = self.count - 1
        return self.count
    }
    
    fn get() {
        return self.count
    }
}

val counter = Counter()
println("counter.increment(): ", counter.increment())
println("counter.increment(): ", counter.increment())
println("counter.decrement(): ", counter.decrement())
println("counter.get(): ", counter.get())

