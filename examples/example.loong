// ====================
// 16. 综合示例
// ====================

println("\n=== 综合示例: 简易计算器 ===")

class Calculator {
    fn __init__() {
        self.history = []
    }
    
    fn add(a, b) {
        val result = a + b
        self.log(str(a) + " + " + str(b) + " = " + str(result))
        return result
    }
    
    fn subtract(a, b) {
        val result = a - b
        self.log(str(a) + " - " + str(b) + " = " + str(result))
        return result
    }
    
    fn multiply(a, b) {
        val result = a * b
        self.log(str(a) + " * " + str(b) + " = " + str(result))
        return result
    }
    
    fn divide(a, b) {
        if b == 0 {
            throw "除数不能为零"
        }
        val result = a / b
        self.log(str(a) + " / " + str(b) + " = " + str(result))
        return result
    }
    
    fn log(entry) {
        push(self.history, entry)
    }
    
    fn show_history() {
        println("计算历史:")
        for val item in self.history {
            println("  ", item)
        }
    }
}

val calc = Calculator()
println("10 + 5 = ", calc.add(10, 5))
println("10 - 3 = ", calc.subtract(10, 3))
println("10 * 4 = ", calc.multiply(10, 4))
println("10 / 2 = ", calc.divide(10, 2))
calc.show_history()

// 处理除零错误
try {
    calc.divide(10, 0)
} catch (e) {
    println("错误: ", e)
}

