println("person: ", person)
println("person.name: ", person.name)
println("person.age: ", person.age)

// ====================
// 7. 条件语句
// ====================

println("\n=== 条件语句 ===")
val score = 85

if score >= 90 {
    println("优秀")
} else {
    if score >= 80 {
        println("良好")
    } else {
        if score >= 60 {
            println("及格")
        } else {
            println("不及格")
        }
    }
}

// ====================
// 8. 循环
// ====================

println("\n=== 循环 ===")

// 传统 for 循环
print("for循环: ")
for val i = 0; i < 5; i = i + 1 {
    print(i, " ")
}
println()

// for-in 循环
print("for-in循环: ")
for val item in [10, 20, 30] {
    print(item, " ")
}
println()

// while 循环
print("while循环: ")
val count = 0
while count < 3 {
    print(count, " ")
    count = count + 1
}
println()

// break 和 continue
print("break示例: ")
for val i = 0; i < 10; i = i + 1 {
    if i == 5 {
        break
    }
    print(i, " ")
}
println()

print("continue示例: ")
for val i = 0; i < 5; i = i + 1 {
    if i == 2 {
        continue
    }
    print(i, " ")
}
println()

// range函数
println("range(5): ", range(5))
println("range(2, 7): ", range(2, 7))

// ====================
// 9. 函数定义
// ====================

println("\n=== 函数定义 ===")

// 基本函数
fn greet(name) {
    return "Hello, " + name + "!"
}
println(greet("Loong"))

// 默认参数
fn power(base, exp = 2) {
    val result = 1
    for val i = 0; i < exp; i = i + 1 {
        result = result * base
    }
    return result
}
println("power(3): ", power(3))
println("power(3, 4): ", power(3, 4))

// 递归函数
fn factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}
println("factorial(10): ", factorial(10))

